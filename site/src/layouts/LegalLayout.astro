---
/**
 * Simple prose layout for legal / policy pages: header band + readable column.
 */
import BaseLayout from './BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { breadcrumbSchema } from '../lib/schema'

interface Props {
  title: string
  description: string
  heading: string
  updated: string
  path: string
}
const { title, description, heading, updated, path } = Astro.props
---

<BaseLayout
  title={title}
  description={description}
  schema={[breadcrumbSchema([{ name: 'Home', path: '/' }, { name: heading, path }])]}
>
  <Header />

  <header class="band">
    <div class="band-inner">
      <p class="eyebrow">Legal</p>
      <h1>{heading}</h1>
      <p class="updated">Last updated: {updated}</p>
    </div>
  </header>

  <main class="prose">
    <slot />
  </main>

  <Footer />
</BaseLayout>

<style>
  .band {
    background: #e4edf3;
  }
  .band-inner {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg) var(--space-xl);
  }
  .eyebrow {
    display: inline-block;
    background: var(--color-primary);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.7rem;
    margin: 0 0 var(--space-md);
  }
  .band h1 {
    font-family: var(--font-body);
    font-size: 44px;
    font-weight: 600;
    letter-spacing: -1px;
    color: var(--color-primary);
    margin: 0;
  }
  .updated {
    color: var(--color-muted);
    font-size: 0.9rem;
    margin: var(--space-sm) 0 0;
  }

  .prose {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg);
    color: var(--color-slate);
    line-height: 1.7;
  }
  .prose :global(h2) {
    font-size: 1.5rem;
    color: var(--color-ink);
    margin: var(--space-xl) 0 var(--space-sm);
  }
  .prose :global(p),
  .prose :global(ul) {
    margin: 0 0 var(--space-md);
  }
  .prose :global(ul) {
    padding-left: 1.4rem;
  }
  .prose :global(li) {
    margin-bottom: var(--space-xs);
  }
  .prose :global(a) {
    color: var(--color-primary);
  }
</style>
