---
import { NAV } from '../lib/site'

interface Props {
  /** Transparent, white-on-image variant that sits over a hero. */
  overlay?: boolean
}
const { overlay = false } = Astro.props
---

<header class:list={['site-header', overlay && 'overlay']}>
  <a href="/" class="brand" aria-label="Teché Health Services — home">
    <img
      src={overlay ? '/TC-Logo_logo-white.png' : '/TC-Logo.png'}
      alt="Teché Health Services"
      width="155"
      height="54"
    />
  </a>

  <nav aria-label="Primary">
    <ul class="nav">
      {
        NAV.map((item) => (
          <li class={'children' in item ? 'has-children' : ''}>
            <a href={item.href}>
              {item.label}
              {'children' in item && <span class="caret" aria-hidden="true">▾</span>}
            </a>
            {'children' in item && (
              <ul class="submenu">
                {item.children.map((child) => (
                  <li>
                    <a href={child.href}>{child.label}</a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ul>
  </nav>

  <a href="/contact/" class="cta">Contact us</a>
</header>

<style>
  /* Measured from the live site: 80px tall, transparent, sitting on the hero. */
  .site-header {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    height: var(--header-height);
    padding: 0 var(--space-lg);
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-rule);
  }

  .site-header.overlay {
    position: absolute;
    inset: 0 0 auto;
    z-index: 10;
    background: transparent;
    border-bottom: none;
  }

  .brand img {
    width: 155px;
    height: auto;
    display: block;
  }

  nav {
    margin-inline-start: auto;
  }

  .nav {
    display: flex;
    gap: var(--space-md);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav > li {
    position: relative;
  }

  /* Nav: Inter 15px/600, white over the hero. */
  .nav a {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 600;
    color: var(--color-ink);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .overlay .nav a {
    color: #fff;
  }

  .caret {
    font-size: 0.7em;
  }

  .submenu {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 16rem;
    background: #fff;
    padding: var(--space-xs) 0;
    list-style: none;
    margin: 0;
    display: none;
    box-shadow: 0 8px 24px rgb(0 0 0 / 12%);
  }

  .has-children:hover .submenu,
  .has-children:focus-within .submenu {
    display: block;
  }

  .submenu a,
  .overlay .submenu a {
    display: block;
    padding: 0.5rem var(--space-sm);
    font-weight: 500;
    color: var(--color-ink);
  }

  .submenu a:hover {
    color: var(--color-primary);
  }

  /* CTA: square, outlined over the hero; solid elsewhere. */
  .cta {
    flex-shrink: 0;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    padding: 16.5px 32px;
    border-radius: 0;
    background: var(--color-primary);
    color: #fff;
    border: 1px solid var(--color-primary);
  }

  .overlay .cta {
    background: transparent;
    color: #fff;
    border: 1px solid rgb(255 255 255 / 70%);
  }

  .overlay .cta:hover {
    background: #fff;
    color: #161616;
  }

  @media (max-width: 1000px) {
    nav {
      display: none;
    }
  }
</style>
