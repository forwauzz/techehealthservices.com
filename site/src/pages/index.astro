---
/**
 * Homepage — structural port of the live WordPress home.
 *
 * Content is lifted verbatim from the archive EXCEPT the values section, which
 * on the live site is unmodified VamTam "Beratung" theme demo copy written for
 * financial advisors ("your clients' financial situations", "financial goals").
 * That copy is replaced here with healthcare-appropriate text — see the note in
 * ARCHIVE.md. Everything else matches.
 */
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

const services = [
  {
    number: '01',
    name: 'AI Scribe',
    href: '/practice-areas/ai-scribe/',
    image: '/img/shutterstock_1722857038-1024x983.jpg',
    imageAlt:
      'A clinician taking notes during a patient consultation while ambient documentation runs',
    items: [
      {
        title: 'Automate Your Documentation',
        body:
          'AI Scribe transcribes physician-patient conversations into clinically ' +
          'relevant notes, reducing administrative burdens and freeing up more ' +
          'time for patient care.',
      },
      {
        title: 'Boost Patient Engagement',
        body:
          'By handling tasks like data entry and referrals through advanced AI, ' +
          'AI Scribe allows physicians to focus on meaningful interactions with ' +
          'their patients.',
      },
      {
        title: 'Seamless Integration & Efficiency',
        body:
          'Unlike basic dictation tools, AI Scribe integrates notes directly into ' +
          'EMRs, sets reminders, and processes orders, streamlining your workflow ' +
          'for improved practice management.',
      },
    ],
  },
  {
    number: '02',
    name: 'Total EMR',
    href: '/practice-areas/emr-services/',
    image: '/img/shutterstock_2187807981-1024x983.jpg',
    imageAlt:
      'A healthcare professional reviewing an electronic medical record on a tablet with a patient',
    items: [
      {
        title: 'Tailored EHR Solutions',
        body:
          'Total EMR offers a step-by-step process to find and customize the ' +
          'perfect EHR system for your practice, ensuring seamless integration, ' +
          'efficiency, and improved patient care.',
      },
      {
        title: 'Expert Project Management',
        body:
          'From assessment to implementation, our experienced project managers ' +
          'guide you through EHR conversion and compliance, minimizing stress, ' +
          'meeting federal mandates, and optimizing practice workflows.',
      },
      {
        title: 'Comprehensive Training & Support',
        body:
          'Total EMR provides specialized training solutions, empowering your ' +
          'staff with effective tools, tailored training plans, and ongoing ' +
          'support to maximize system adoption and improve patient outcomes.',
      },
    ],
  },
  {
    number: '03',
    name: 'IT Services',
    href: '/practice-areas/it-services/',
    image: '/img/shutterstock_2463474777-1024x983.jpg',
    imageAlt:
      'Clinic staff working at networked computer workstations in a medical office',
    items: [
      {
        title: 'Optimized Communication Systems',
        body:
          "We assess your practice's unique communication needs, providing " +
          'customized phone system solutions, from traditional landlines to VoIP ' +
          'and cloud-based options, for efficient and scalable communication.',
      },
      {
        title: 'Customized Computer Solutions',
        body:
          'Our team helps select and configure computers tailored to your ' +
          "practice's specific needs, ensuring optimal performance, software " +
          'compatibility, and cost-effectiveness for seamless operations.',
      },
      {
        title: 'Seamless Digital Transformation',
        body:
          'Transition from paper to digital with our expert strategies, enhancing ' +
          'clinical and non-clinical workflows, reducing inefficiencies, and ' +
          'empowering your practice to fully embrace digital technology.',
      },
    ],
  },
]

/**
 * Replaces the theme's financial-advisor demo copy. Same six pillars, same
 * structure, written for a healthcare consulting practice.
 */
const values = [
  {
    title: 'Integrity',
    body:
      'Uphold high ethical standards and act with honesty, transparency, and ' +
      'professionalism in every engagement.',
  },
  {
    title: 'Trust and Confidentiality',
    body:
      'Patient data and practice operations demand discretion. Confidentiality ' +
      'is treated as a clinical obligation, not a formality.',
  },
  {
    title: 'Objectivity',
    body:
      'Vendor-neutral advice grounded in analysis of your actual workflows, ' +
      'not in reseller relationships or commissions.',
  },
  {
    title: 'Expertise',
    body:
      'More than a decade inside clinical settings — private practice and RAMQ ' +
      'clinics alike — kept current with the tools and regulations that matter.',
  },
  {
    title: 'Long-Term Relationships',
    body:
      'Implementation is the beginning, not the end. Support continues well ' +
      'past go-live, because that is when the real questions surface.',
  },
  {
    title: 'Accountability',
    body:
      'Progress is monitored, strategies reviewed, and adjustments made so your ' +
      'practice actually reaches the outcomes it set out to achieve.',
  },
]

const testimonials = [
  {
    name: 'Kamelia Emamian',
    body:
      'Thank you Uzziel for helping us navigate different EMRs to find one best ' +
      'suited for our services and then help establish that EMR. I have a super ' +
      'busy schedule and I appreciate you being on top of everything and ' +
      'following up. Your attention and care is much appreciated.',
  },
  {
    name: 'Marcel Severe',
    body:
      'TECHE Health Services in one word "AMAZING". Great services. Adjusts to ' +
      'client needs. Available to provide technical support. One text away to ' +
      'solve any issue and provide accurate counselling. Great tools to make ' +
      'office work easier.',
  },
]

/** "Interested in" dropdown — options lifted from the live form. */
const interests = [
  'AI Scribe',
  'EMR Training',
  'EMR Optimization',
  'EMR Systems Implementation',
  'IT Services',
  'Other',
]

/** The three existing posts, surfaced on the homepage as on the live site. */
const insights = [
  {
    title: 'Integrated Soft phones & EMRs',
    href: '/integrated-soft-phones-emrs/',
    image: '/img/image-768x514.jpg',
    category: 'Integration',
    excerpt:
      'Investors must navigate uncertain times and unpredictable waters. Effective ' +
      'strategies, like diversifying portfolios and analyzing markets.',
  },
  {
    title: 'Elevate your Healthcare facility with Expert EMR Consulting',
    href: '/elevate-your-healthcare-facility-with-expert-emr-consulting/',
    image: '/img/shutterstock_2072581631-768x472.jpg',
    category: 'Insights',
    excerpt:
      'Investors must navigate uncertain times and unpredictable waters. Effective ' +
      'strategies, like diversifying portfolios and analyzing markets.',
  },
  {
    title: 'Systems Software Implementation: the psychological approach',
    href: '/systems-software-psychological-approach/',
    image: '/img/shutterstock_2486103943-768x472.jpg',
    category: 'Support',
    excerpt:
      'Investors must navigate uncertain times and unpredictable waters. Effective ' +
      'strategies, like diversifying portfolios and analyzing markets.',
  },
]
---

<BaseLayout
  title="Clinical Operations Consultant"
  description="Teché Health Services helps Montreal clinics select, implement, and optimize EMR systems and AI scribe tools — reducing documentation burden and making healthcare technology work."
>
  <section class="hero">
    <Header overlay />
    <div class="hero-inner">
      <h1>Clinical Operations<br />Consultant</h1>
      <p class="rotator" aria-label="We simplify healthcare tech">
        <span>We simplify Healthcare tech</span>
        <span>Tailored EHR solutions</span>
        <span>Automate your documentation</span>
      </p>
      <h2 class="sub">
        From system integration to on-site training, we make healthcare
        technology work for you.
      </h2>
      <a href="/contact/" class="btn">Schedule a free consultation</a>
    </div>
  </section>

  <main>
    <section class="services">
      <p class="eyebrow">Specialized Services</p>
      <h2>To meet your needs — AI Scribe, Total EMR, Training, IT</h2>

    </section>

    {
      services.map((group) => (
        <section class="band">
          <div class="band-inner">
            <img class="band-photo" src={group.image} alt={group.imageAlt} width="506" height="486" loading="lazy" />
            <h3 class="band-title">
              <a href={group.href}>{group.name}</a>
            </h3>
            <div class="band-card">
              {group.items.map((item) => (
                <article>
                  <h4>
                    <a href={group.href}>{item.title} &gt;</a>
                  </h4>
                  <p>{item.body}</p>
                </article>
              ))}
            </div>
            <p class="band-index">
              {group.number} {group.name}
            </p>
          </div>
        </section>
      ))
    }

    <section class="guide">
      <img
        class="guide-photo"
        src="/img/uzziel-portrait.jpg"
        alt="Uzziel Tamon, Clinical Applications & AI Consultant at Teché Health Services"
        width="480"
        height="720"
        loading="lazy"
      />
      <div class="guide-panel">
        <h2>I can guide you through every step of your health tech journey.</h2>
        <div class="guide-grid">
          {
            values.map((v) => (
              <article>
                <span class="check" aria-hidden="true">✓</span>
                <h3>{v.title}</h3>
                <p>{v.body}</p>
              </article>
            ))
          }
        </div>
        <a href="/about/" class="guide-more">Learn More</a>
      </div>
    </section>

    <section class="testimonials">
      <p class="eyebrow">Testimonials</p>
      <h2>Those who trust us</h2>
      <div class="grid">
        {
          testimonials.map((t) => (
            <figure>
              <blockquote>{t.body}</blockquote>
              <figcaption>{t.name}</figcaption>
            </figure>
          ))
        }
      </div>
    </section>

    <section class="contact-cta">
      <p class="eyebrow">Get started</p>
      <h2>Schedule your personalized consultation today</h2>
      <p class="contact-lede">Drop your contact details into the form, and we'll reach out to you!</p>

      {/*
        Static build has no form backend yet. This posts to a Cloudflare Pages
        Function / Brevo endpoint added at wiring time; until then it is inert.
        See TODO in the repo. Fields mirror the live Elementor form exactly.
      */}
      <form class="contact-form" method="post" action="/api/contact" novalidate>
        <div class="field">
          <label for="name">Name</label>
          <input id="name" name="name" type="text" autocomplete="name" required />
        </div>
        <div class="row">
          <div class="field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" autocomplete="email" required />
          </div>
          <div class="field">
            <label for="phone">Phone number</label>
            <input id="phone" name="phone" type="tel" autocomplete="tel" />
          </div>
        </div>
        <div class="row">
          <div class="field">
            <label for="company">Company name</label>
            <input id="company" name="company" type="text" autocomplete="organization" />
          </div>
          <div class="field">
            <label for="website">Website</label>
            <input id="website" name="website" type="url" />
          </div>
        </div>
        <div class="field">
          <label for="interest">Interested in</label>
          <select id="interest" name="interest">
            {interests.map((o) => <option value={o}>{o}</option>)}
          </select>
        </div>
        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="4" placeholder="Tell us more about your needs..."></textarea>
        </div>
        <button type="submit" class="btn-solid">Submit</button>
      </form>
    </section>

    <section class="insights">
      <p class="eyebrow">Insights</p>
      <h2>Valuable insights that empower your decision-making</h2>
      <div class="insights-grid">
        {
          insights.map((post) => (
            <article class="post-card">
              <a href={post.href} class="post-thumb">
                <img src={post.image} alt={post.title} width="384" height="236" loading="lazy" />
              </a>
              <p class="post-cat">{post.category}</p>
              <h3>
                <a href={post.href}>{post.title}</a>
              </h3>
              <p class="post-excerpt">{post.excerpt}</p>
              <a href={post.href} class="post-more">Read More</a>
            </article>
          ))
        }
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  section {
    padding: var(--space-2xl) 0;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0 0 var(--space-xs);
  }

  /*
   * Hero — values measured from the live site's computed styles:
   * background cover at 50% 0%, min-height 720px, and a 55deg black gradient
   * overlay from 51% opacity at 30% to transparent at 60%.
   */
  .hero {
    position: relative;
    min-height: max(var(--hero-height), 100vh);
    padding: 0 30px;
    background-image: url('/hero.jpg');
    background-size: cover;
    background-position: 50% 0%;
    background-repeat: no-repeat;
    display: flex;
    align-items: flex-end;
    isolation: isolate;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--hero-overlay);
    z-index: -1;
  }

  .hero-inner {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding-bottom: 3.5rem;
    color: #fff;
  }

  /* Inter 60px / 72px, weight 500, letter-spacing -2px. */
  .hero h1 {
    font-size: 60px;
    line-height: 72px;
    font-weight: 500;
    letter-spacing: -2px;
    color: #fff;
    margin: 0;
  }

  /* The animated headline: same size, heavier weight, cycling three phrases. */
  .rotator {
    position: relative;
    display: block;
    height: 72px;
    margin: 0 0 18px;
    font-family: var(--font-heading);
    font-size: 60px;
    line-height: 72px;
    font-weight: 700;
    letter-spacing: -2px;
  }

  .rotator span {
    position: absolute;
    inset: 0;
    opacity: 0;
    animation: rotate-headline 12s infinite;
    white-space: nowrap;
  }

  .rotator span:nth-child(2) {
    animation-delay: 4s;
  }

  .rotator span:nth-child(3) {
    animation-delay: 8s;
  }

  @keyframes rotate-headline {
    0%,
    3% { opacity: 0; transform: translateY(8px); }
    6%,
    30% { opacity: 1; transform: none; }
    34%,
    100% { opacity: 0; transform: translateY(-8px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .rotator span {
      animation: none;
    }
    .rotator span:nth-child(2) {
      opacity: 1;
    }
  }

  /* Geologica 20px / 26px, weight 400, letter-spacing -0.4px. */
  .sub {
    font-family: var(--font-body);
    font-size: 20px;
    line-height: 26px;
    font-weight: 400;
    letter-spacing: -0.4px;
    color: #fff;
    max-width: 46ch;
    margin: 0 0 var(--space-md);
  }

  /* White, square, Geologica 14px/600, padding 16.5px 32px. */
  .btn {
    display: inline-block;
    background: #fff;
    color: #161616;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    padding: 16.5px 32px;
    border-radius: 0;
  }

  .btn:hover {
    background: var(--color-primary);
    color: #fff;
  }

  @media (max-width: 700px) {
    .hero h1,
    .rotator {
      font-size: 38px;
      line-height: 46px;
      letter-spacing: -1px;
    }
    .rotator {
      height: 46px;
    }
  }

  /*
   * Service bands. Measured from the original:
   *   heading  Geologica 70px / 700 / rgba(0,0,0,.5) / letter-spacing -2.8px
   *   photo    506x486, masked with the brand symbol SVG (the angled shape)
   *   card     white, padding 70px 30px 50px, three columns
   *   motion   card is position:sticky within the band; photo parallaxes
   */
  .band {
    /* Break out of main's max-width to go full-bleed. */
    width: 100vw;
    margin-left: calc(50% - 50vw);
    background: var(--color-primary-tint);
    padding: var(--space-2xl) 30px;
  }

  .band + .band {
    padding-top: var(--space-xl);
  }

  /*
   * Height matters here: the sticky card can only pin for as long as its
   * parent extends below it. The original band is ~1800px tall, which is what
   * gives the card its long pinned travel. At 620px there was effectively zero
   * range and the card slid straight past.
   */
  .band-inner {
    position: relative;
    max-width: 1165px;
    margin: 0 auto;
    min-height: 1050px;
  }

  .band-photo {
    position: absolute;
    top: 0;
    right: 0;
    width: 506px;
    height: 486px;
    object-fit: cover;
    /* The angled parallelogram is the brand symbol used as a mask. */
    mask-image: url('/img/brand-symbol-bg-mask.svg');
    mask-size: contain;
    mask-position: 50% 50%;
    mask-repeat: no-repeat;
    -webkit-mask-image: url('/img/brand-symbol-bg-mask.svg');
    -webkit-mask-size: contain;
    -webkit-mask-position: 50% 50%;
    -webkit-mask-repeat: no-repeat;
  }

  .band-title {
    font-family: var(--font-body);
    font-size: 70px;
    font-weight: 700;
    letter-spacing: -2.8px;
    line-height: 1.1;
    color: rgb(0 0 0 / 50%);
    margin: 0;
    padding-top: 180px;
  }

  .band-title a {
    color: inherit;
    text-decoration: none;
  }

  .band-card {
    position: sticky;
    top: 90px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    background: #fff;
    padding: 70px 30px 50px;
    margin-top: var(--space-md);
    max-width: 858px;
    gap: var(--space-md);
  }

  .band-card h4 {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.4px;
    line-height: 1.4;
    margin: 0 0 var(--space-sm);
  }

  .band-card h4 a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .band-card p {
    margin: 0;
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-slate);
  }

  .band-index {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-muted);
    text-align: center;
    margin: var(--space-lg) 0 0;
  }

  /* The translateY motion effect, expressed as a scroll-driven animation
     where supported. Static and harmless everywhere else. */
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .band-photo {
        animation: band-parallax linear both;
        animation-timeline: view();
        animation-range: entry 0% cover 66%;
      }
    }
  }

  @keyframes band-parallax {
    from {
      transform: translateY(60px);
    }
    to {
      transform: translateY(-60px);
    }
  }

  @media (max-width: 1000px) {
    .band-photo {
      position: static;
      width: 100%;
      height: auto;
      margin-bottom: var(--space-md);
    }
    .band-title {
      padding-top: 0;
      font-size: 44px;
      letter-spacing: -1.6px;
    }
    .band-card {
      position: static;
      grid-template-columns: 1fr;
      padding: var(--space-lg) var(--space-md);
    }
  }

  /* Guide: portrait left, pale-green panel (#9ED09E) with the six values right. */
  .guide {
    display: grid;
    grid-template-columns: 480px 1fr;
    align-items: stretch;
    gap: 0;
    padding: var(--space-2xl) 0;
  }

  .guide-photo {
    width: 480px;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .guide-panel {
    background: #9ed09e;
    padding: var(--space-xl);
  }

  .guide-panel > h2 {
    font-size: 25px;
    font-weight: 600;
    letter-spacing: -0.5px;
    max-width: 18ch;
    margin: 0 0 var(--space-lg);
  }

  .guide-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md) var(--space-lg);
  }

  .check {
    display: block;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 0.4rem;
  }

  .guide-grid h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.3rem;
  }

  .guide-grid p {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--color-slate);
  }

  .guide-more {
    display: inline-block;
    margin-top: var(--space-lg);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14px;
    color: var(--color-ink);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .testimonials .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr));
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  blockquote {
    margin: 0;
    font-size: 1.05rem;
    color: var(--color-slate);
  }

  figcaption {
    margin-top: var(--space-sm);
    font-weight: 600;
  }

  /* Contact form. */
  .contact-lede {
    color: var(--color-slate);
    margin: 0 0 var(--space-lg);
  }

  .contact-form {
    max-width: 640px;
  }

  .contact-form .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .field {
    margin-bottom: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .field label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-slate);
  }

  .field input,
  .field select,
  .field textarea {
    font-family: var(--font-body);
    font-size: 0.95rem;
    padding: 0.7rem 0.85rem;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
    background: #fff;
    color: var(--color-ink);
  }

  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: 2px solid var(--color-primary-accent);
    border-color: var(--color-primary);
  }

  /* Insights: three post cards. */
  .insights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .post-thumb img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: var(--radius);
  }

  .post-cat {
    margin: var(--space-sm) 0 0.2rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    font-weight: 600;
  }

  .post-card h3 {
    font-size: 1.15rem;
    margin: 0 0 var(--space-xs);
  }

  .post-card h3 a {
    color: var(--color-ink);
    text-decoration: none;
  }

  .post-excerpt {
    margin: 0 0 var(--space-sm);
    font-size: 0.9rem;
    color: var(--color-slate);
  }

  .post-more {
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
  }

  .btn-solid {
    display: inline-block;
