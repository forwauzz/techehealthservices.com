---
/**
 * Practice areas index — the "Services" landing page.
 *
 * The live version's intro was theme demo copy about "strategy, marketing,
 * mergers & acquisitions, and sustainability" — generic consulting boilerplate,
 * not healthcare. Rewritten for what Teché actually does, listing the real
 * services from the collection.
 */
import BaseLayout from '../../layouts/BaseLayout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import { getCollection } from 'astro:content'
import { breadcrumbSchema } from '../../lib/schema'

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order
)
---

<BaseLayout
  title="Services & Practice Areas"
  description="Teché Health Services' practice areas — AI scribe adoption, EMR selection and implementation, optimization, training, and IT services for Montreal clinics."
  schema={[breadcrumbSchema([{ name: 'Home', path: '/' }, { name: 'Services', path: '/practice-areas/' }])]}
>
  <Header />

  <header class="band">
    <div class="band-inner">
      <p class="eyebrow">Practice Areas</p>
      <h1>Not your average consultant</h1>
    </div>
  </header>

  <main>
    <div class="intro">
      <p>
        My expertise spans the systems clinics actually run on — EMR and EHR
        platforms, AI documentation tools, billing, training, and the IT that
        ties them together. From vendor selection to on-site training, I help
        practices make healthcare technology work.
      </p>
      <p>
        What sets the work apart is a holistic view of clinic operations.
        Having spent more than a decade inside busy medical centers, I
        understand how these pieces connect — and where the real inefficiencies
        hide. Whether you're a solo physician or a multi-provider clinic, the
        goal is the same: less chaos, more clarity.
      </p>
    </div>

    <div class="grid">
      {
        services.map((s) => (
          <a href={`/practice-areas/${s.id}/`} class="card">
            <h2>
              {s.data.heading} <span aria-hidden="true">›</span>
            </h2>
            <p>{s.data.description}</p>
          </a>
        ))
      }
      <div class="card note">
        <p>If you don't see your specific practice area, please reach out.</p>
        <a href="/contact/" class="btn-outline">Contact us</a>
      </div>
    </div>

    <section class="cta">
      <h2>Your growth is my growth.</h2>
      <p>
        I combine in-market experience with knowledge of top industry trends to
        provide you with actionable clinical solutions.
      </p>
      <a href="/insights/" class="btn-outline">See our Insights</a>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .band {
    background: #e4edf3;
  }
  .band-inner {
    max-width: 1165px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg) var(--space-xl);
  }
  .eyebrow {
    display: inline-block;
    background: var(--color-primary);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.7rem;
    margin: 0 0 var(--space-md);
  }
  .band h1 {
    font-family: var(--font-body);
    font-size: 48px;
    font-weight: 600;
    letter-spacing: -1px;
    color: var(--color-primary);
    margin: 0;
  }

  main {
    max-width: 1165px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg);
  }

  .intro {
    max-width: 65ch;
    margin: 0 0 var(--space-2xl);
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--color-slate);
  }
  .intro p {
    margin: 0 0 var(--space-md);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg) var(--space-2xl);
  }

  .card {
    text-decoration: none;
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: var(--space-md);
  }
  .card h2 {
    font-size: 1.3rem;
    font-weight: 600;
    margin: 0 0 var(--space-xs);
    display: flex;
    justify-content: space-between;
    gap: var(--space-sm);
    color: var(--color-primary);
  }
  .card p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-slate);
  }

  .note {
    background: #e4edf3;
    border: none;
    border-radius: var(--radius);
    padding: var(--space-lg);
  }
  .note p {
    margin: 0 0 var(--space-md);
    font-weight: 500;
    color: var(--color-ink);
  }

  .btn-outline {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    padding: 12px 26px;
    border: 1px solid var(--color-primary);
  }
  .btn-outline:hover {
    background: var(--color-primary);
    color: #fff;
  }

  .cta {
    margin-top: var(--space-2xl);
    border-top: 1px solid var(--color-rule);
    padding-top: var(--space-2xl);
    max-width: 55ch;
  }
  .cta h2 {
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -1px;
    margin: 0 0 var(--space-sm);
  }
  .cta p {
    color: var(--color-slate);
    margin: 0 0 var(--space-lg);
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
