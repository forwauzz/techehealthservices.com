---
/**
 * Podcast episode page. Mirrors the live layout (date, title, intro, embed),
 * but adds two things the original lacked and that matter for search:
 *   1. PodcastEpisode structured data
 *   2. A transcript slot. An embed is invisible to crawlers; the transcript is
 *      what turns an episode into an indexable page. Rendered when present.
 */
import { getCollection, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import { podcastEpisodeSchema, breadcrumbSchema } from '../../lib/schema'

export async function getStaticPaths() {
  const episodes = await getCollection('podcasts', ({ data }) => !data.draft)
  return episodes.map((entry) => ({
    params: { episode: entry.id },
    props: { entry },
  }))
}

const { entry } = Astro.props
const d = entry.data
const path = `/podcasts/${entry.id}/`
const { Content } = await render(entry)

const schema = [
  podcastEpisodeSchema({
    title: d.title,
    description: d.description,
    path,
    published: d.published,
    episodeNumber: d.episodeNumber,
    duration: d.duration,
  }),
  breadcrumbSchema([
    { name: 'Home', path: '/' },
    { name: 'Podcasts', path: '/podcasts/' },
    { name: d.title, path },
  ]),
]

const fmtDate = (dt: Date) =>
  dt.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })
---

<BaseLayout title={d.title} description={d.description} schema={schema} published={d.published}>
  <Header />

  <main>
    <p class="meta">
      <time datetime={d.published.toISOString()}>{fmtDate(d.published)}</time>
      <span aria-hidden="true">•</span>
      <a href="/podcasts/">Podcasts</a>
    </p>
    <h1>{d.title}</h1>
    <p class="intro">{d.description}</p>

    {
      d.spotifyId && (
        <div class="embed">
          <iframe
            src={`https://open.spotify.com/embed/episode/${d.spotifyId}?utm_source=generator`}
            width="100%"
            height="352"
            frameborder="0"
            allowfullscreen
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            loading="lazy"
            title={`Listen: ${d.title}`}
          />
        </div>
      )
    }

    {
      d.hasTranscript && (
        <section class="transcript">
          <h2>Episode transcript</h2>
          <div class="prose">
            <Content />
          </div>
        </section>
      )
    }
  </main>

  <Footer />
</BaseLayout>

<style>
  main {
    max-width: 820px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg);
  }

  .meta {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    color: var(--color-muted);
    font-size: 0.9rem;
    margin: 0 0 var(--space-md);
  }

  .meta a {
    color: var(--color-muted);
    text-decoration: none;
  }

  h1 {
    font-family: var(--font-body);
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -1.5px;
    text-align: center;
    margin: 0 0 var(--space-lg);
  }

  .intro {
    text-align: center;
    max-width: 60ch;
    margin: 0 auto var(--space-xl);
    color: var(--color-slate);
    font-size: 1.1rem;
  }

  .embed {
    border-radius: 12px;
    overflow: hidden;
  }

  .transcript {
    margin-top: var(--space-2xl);
    border-top: 1px solid var(--color-rule);
    padding-top: var(--space-xl);
  }

  .transcript h2 {
    font-size: 1.6rem;
    margin: 0 0 var(--space-md);
  }

  .prose {
    color: var(--color-slate);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .prose :global(p) {
    margin: 0 0 var(--space-md);
  }
</style>
