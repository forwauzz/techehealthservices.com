---
/**
 * Podcasts index. Header band + episode cards linking to each episode page.
 */
import BaseLayout from '../../layouts/BaseLayout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import { getCollection } from 'astro:content'
import { breadcrumbSchema } from '../../lib/schema'

const episodes = (await getCollection('podcasts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf()
)

const fmtDate = (dt: Date) =>
  dt.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })
---

<BaseLayout
  title="Podcasts — Teché Talks"
  description="Teché Talks: conversations with healthcare innovators solving problems in healthcare with AI and technology. Hosted by Uzziel Tamon."
  schema={[breadcrumbSchema([{ name: 'Home', path: '/' }, { name: 'Podcasts', path: '/podcasts/' }])]}
>
  <Header />

  <header class="band">
    <div class="band-inner">
      <p class="eyebrow">Podcasts</p>
      <h1>Teché Talks</h1>
      <p class="tagline">
        Conversations with healthcare innovators solving real problems with AI and technology.
      </p>
    </div>
  </header>

  <main>
    <div class="grid">
      {
        episodes.map((ep) => (
          <a href={`/podcasts/${ep.id}/`} class="card">
            {ep.data.episodeNumber && <p class="ep-num">Episode {ep.data.episodeNumber}</p>}
            <h2>{ep.data.title}</h2>
            <p class="ep-desc">{ep.data.description}</p>
            <p class="ep-meta">
              <time datetime={ep.data.published.toISOString()}>{fmtDate(ep.data.published)}</time>
              <span class="listen">Listen →</span>
            </p>
          </a>
        ))
      }
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .band {
    background: #e4edf3;
  }
  .band-inner {
    max-width: 1165px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg) var(--space-xl);
  }
  .eyebrow {
    display: inline-block;
    background: var(--color-primary);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.7rem;
    margin: 0 0 var(--space-md);
  }
  .band h1 {
    font-family: var(--font-body);
    font-size: 48px;
    font-weight: 600;
    letter-spacing: -1px;
    color: var(--color-primary);
    margin: 0;
  }
  .tagline {
    color: var(--color-slate);
    font-size: 1.1rem;
    max-width: 52ch;
    margin: var(--space-sm) 0 0;
  }

  main {
    max-width: 1165px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-lg) var(--space-2xl);
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  .card {
    text-decoration: none;
    color: var(--color-ink);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
  }

  .ep-num {
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 var(--space-xs);
  }

  .card h2 {
    font-size: 1.4rem;
    margin: 0 0 var(--space-sm);
    letter-spacing: -0.5px;
  }

  .ep-desc {
    color: var(--color-slate);
    font-size: 0.95rem;
    margin: 0 0 var(--space-md);
    flex: 1;
  }

  .ep-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .listen {
    color: var(--color-primary);
    font-weight: 600;
  }

  @media (max-width: 800px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
