---
/**
 * Insights index. Header band, category filter pills, post-card grid.
 * Pills filter client-side; with JS off, all posts show.
 */
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { getCollection } from 'astro:content'
import { breadcrumbSchema } from '../lib/schema'

const posts = (await getCollection('insights', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf()
)

const categories = ['All', ...new Set(posts.map((p) => p.data.category))]
---

<BaseLayout
  title="Insights"
  description="Valuable insights on clinical AI, EMR strategy, and healthcare operations — written analysis from Teché Health Services to empower your decision-making."
  schema={[breadcrumbSchema([{ name: 'Home', path: '/' }, { name: 'Insights', path: '/insights/' }])]}
>
  <Header />

  <header class="band">
    <div class="band-inner">
      <p class="eyebrow">Insights</p>
      <div class="band-row">
        <h1>Valuable Insights</h1>
        <a href="/podcasts/" class="btn-outline">Listen In</a>
      </div>
    </div>
  </header>

  <main>
    <div class="filters" role="tablist" aria-label="Filter insights by category">
      {
        categories.map((cat, i) => (
          <button class:list={['pill', i === 0 && 'active']} data-filter={cat}>
            {cat}
          </button>
        ))
      }
    </div>

    <div class="grid">
      {
        posts.map((p) => (
          <a href={`/${p.id}/`} class="card" data-category={p.data.category}>
            {p.data.image && <img src={p.data.image} alt={p.data.title} width="384" height="220" loading="lazy" />}
            <p class="card-cat">{p.data.category}</p>
            <h2>{p.data.title}</h2>
            <p class="card-desc">{p.data.description}</p>
          </a>
        ))
      }
    </div>
  </main>

  <Footer />
</BaseLayout>

<script is:inline>
  ;(() => {
    const pills = document.querySelectorAll('.pill')
    const cards = document.querySelectorAll('.card[data-category]')
    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const filter = pill.getAttribute('data-filter')
        pills.forEach((p) => p.classList.toggle('active', p === pill))
        cards.forEach((c) => {
          const show = filter === 'All' || c.getAttribute('data-category') === filter
          c.style.display = show ? '' : 'none'
        })
      })
    })
  })()
</script>

<style>
  .band {
    background: #e4edf3;
  }
  .band-inner {
    max-width: 1165px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg) var(--space-xl);
  }
  .eyebrow {
    display: inline-block;
    background: var(--color-primary);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.3rem 0.7rem;
    margin: 0 0 var(--space-md);
  }
  .band-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }
  .band h1 {
    font-family: var(--font-body);
    font-size: 48px;
    font-weight: 600;
    letter-spacing: -1px;
    color: var(--color-primary);
    margin: 0;
  }
  .btn-outline {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    padding: 16.5px 32px;
    border: 1px solid var(--color-primary);
    white-space: nowrap;
  }
  .btn-outline:hover {
    background: var(--color-primary);
    color: #fff;
  }

  main {
    max-width: 1165px;
    margin: 0 auto;
    padding: var(--space-xl) var(--space-lg) var(--space-2xl);
  }

  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
  }

  .pill {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.45rem 1.1rem;
    border: 1px solid var(--color-rule);
    border-radius: 999px;
    background: #fff;
    color: var(--color-slate);
    cursor: pointer;
  }

  .pill.active {
    background: var(--color-primary-accent);
    border-color: var(--color-primary-accent);
    color: var(--color-ink);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .card {
    text-decoration: none;
    color: var(--color-ink);
    border: 1px solid var(--color-rule);
    padding: var(--space-md);
  }

  .card-cat {
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 var(--space-sm);
  }

  .card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    margin-bottom: var(--space-sm);
  }

  .card h2 {
    font-size: 1.2rem;
    margin: 0 0 var(--space-xs);
  }

  .card-desc {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-slate);
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
